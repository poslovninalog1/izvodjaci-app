# Optional deps (e.g. lightningcss-win32-x64-msvc) must be installed for Tailwind v4.
# If lightningcss fails with "Cannot find module 'unknown'", run:
#   npm config delete omit
#   Remove-Item -Recurse -Force node_modules, package-lock.json, .next -ErrorAction SilentlyContinue
#   npm install --include=optional
# Or: npm run dev:clean:full
