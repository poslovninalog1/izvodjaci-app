# Copy to .env.local and fill with real values. Do not commit .env.local.
# IMPORTANT: Restart dev server (npm run dev) after changing this file!
#
# LOCAL (Docker Supabase):
#   After running: npm run supabase:start
#   Use the API URL and anon key printed by the CLI.
#   Example (replace LOCAL_ANON_KEY with the key from supabase status):

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=LOCAL_ANON_KEY

# Server-only: required for contract PDF upload / storage operations.
# Get from: supabase status (local) or Dashboard > Settings > API (prod).
SUPABASE_SERVICE_ROLE_KEY=LOCAL_SERVICE_ROLE_KEY

#
# PRODUCTION (set in host/Vercel env vars, never commit):
#   NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon JWT>
#   SUPABASE_SERVICE_ROLE_KEY=<service_role JWT>
